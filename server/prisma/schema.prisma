generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id                  Int                @id @default(autoincrement())
  name                String
  role                String             @default("player")
  pin_hash            String
  active_character_id Int?
  active_character    Character?         @relation("ActiveCharacter", fields: [active_character_id], references: [id])
  characters          Character[]        @relation("OwnedCharacters")
  messages_sent       Message[]          @relation("SentMessages")
  messages_received   Message[]          @relation("ReceivedMessages")
  created_at          DateTime           @default(now())
}

model Character {
  id                  Int                @id @default(autoincrement())
  player_id           Int
  player              Player             @relation("OwnedCharacters", fields: [player_id], references: [id])
  name                String
  species             String?
  age                 Int?
  gender              String?
  homeworld           String?
  background          String?
  notes               String?
  portrait_url        String?
  description         String?
  colorScheme         String             @default("")
  isActive            Boolean            @default(false)
  status              String             @default("ACTIVE")
  str                 Int?
  dex                 Int?
  end                 Int?
  int                 Int?
  edu                 Int?
  soc                 Int?
  skills              String             @default("{}")
  character_skills    CharacterSkill[]
  credits             Int                @default(0)
  actions_spent_day   Int?
  action_type_today   String?
  salary_amount       Int?
  salary_interval_days Int?
  last_salary_day     Int?
  skill_points        Int                @default(0)
  total_sp_earned     Int                @default(0)
  activity_points     Int                @default(2)
  active_for_players  Player[]           @relation("ActiveCharacter")
  inventory           InventoryItem[]
  cargo_hold          CargoHold[]
  skill_training      SkillTraining[]
  maintenance_logs    MaintenanceLog[]
  world_notes         WorldNote[]
  investment_actions  InvestmentAction[]
  event_logs          EventLog[]
  skill_point_awards  SkillPointAward[]
  crew_hired          CrewMember[]
  combat_roles        CharacterCombatRole[]
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
}

model CharacterSkill {
  id          Int       @id @default(autoincrement())
  characterId Int
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skillName   String
  level       Int?

  @@unique([characterId, skillName])
}

model Game {
  id                      Int               @id @default(autoincrement())
  name                    String
  current_world_id        Int?
  current_world           World?            @relation(fields: [current_world_id], references: [id])
  in_jump_space           Boolean           @default(false)
  day                     Int               @default(1)
  milieu                  String?
  is_drinax               Boolean           @default(true)
  imperium_standing       Int               @default(0)
  hierate_standing        Int               @default(-5)
  imperium_bounty         Int?
  hierate_bounty          Int?
  combat_round            Int               @default(0)
  store_inventory         StoreInventory[]
  created_at              DateTime          @default(now())
}

model Item {
  id                    Int              @id @default(autoincrement())
  name                  String
  type                  String
  sub_type              String
  tech_level            Int
  law_level             Int              @default(0)
  black_market_category Int              @default(0)
  cost_cr               Float
  mass_kg               Float?
  damage                String?
  protection            String?
  magazine_qty          Int?
  slots                 Int?
  radiation_protection  Int?
  traits                String?
  range                 String?
  required_skill        String?
  reference             String?
  description           String?
  active_in_game        Boolean          @default(false)
  bm_inventory          BMInventory[]
  inventory_items       InventoryItem[]
  store_inventory       StoreInventory[]
  created_at            DateTime         @default(now())
}

model StoreInventory {
  id               Int      @id @default(autoincrement())
  game_id          Int
  item_id          Int
  base_roll        Int
  final_roll       Int
  quantity         Int
  price_multiplier Float    @default(1.0)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  game             Game     @relation(fields: [game_id], references: [id])
  item             Item     @relation(fields: [item_id], references: [id])

  @@unique([game_id, item_id])
}

model SkillTraining {
  id                    Int       @id @default(autoincrement())
  character_id          Int
  character             Character @relation(fields: [character_id], references: [id])
  skill_name            String
  training_days_applied Int       @default(0)
  is_active             Boolean   @default(true)
  started_day           Int
  created_at            DateTime  @default(now())
}

model SkillPointAward {
  id             Int       @id @default(autoincrement())
  character_id   Int
  character      Character @relation(fields: [character_id], references: [id])
  points_awarded Int
  source         String
  skill_name     String?
  reason         String?
  game_day       Int
  created_at     DateTime  @default(now())
}

model World {
  id                    Int              @id @default(autoincrement())
  name                  String
  hex_code              String
  port_type             String
  size                  String
  atmosphere            String
  hydrographics         String
  population            String
  government            String
  law                   String
  technology            String
  trade_codes           String?
  allegiance            String?
  port_attitude         String?
  naval_base            Boolean          @default(false)
  key_system            Boolean          @default(false)
  secure_world          Boolean          @default(false)
  dangerous_world       Boolean          @default(false)
  is_hidden             Boolean          @default(false)
  is_aslan_port         Boolean          @default(false)
  total_donations_cr    Int              @default(0)
  last_supplier_search_day Int?
  crew_available        Boolean          @default(false)
  sector                String?
  subsector             String?
  notes                 String?
  game_as_current       Game[]
  bm_inventory          BMInventory[]
  bm_unlocks            BlackMarketUnlock[]
  world_notes           WorldNote[]
  npcs                  NPC[]
  factions              Faction[]
  piracy_effects        PiracyEffect[]
  spec_cargo            SpecCargo[]
  freight_origin        FreightLot[]     @relation("FreightOrigin")
  freight_destination   FreightLot[]     @relation("FreightDestination")
  passenger_origin      Passenger[]      @relation("PassengerOrigin")
  passenger_destination Passenger[]      @relation("PassengerDestination")
  cargo_sold_here       CargoHold[]      @relation("CargoSoldAt")
  event_logs            EventLog[]
  created_at            DateTime         @default(now())
}

model BMInventory {
  id            Int      @id @default(autoincrement())
  world_id      Int
  world         World    @relation(fields: [world_id], references: [id])
  item_id       Int
  item          Item     @relation(fields: [item_id], references: [id])
  visit_day     Int
  bm_base_roll  Int
  bm_final_roll Int?
  bm_quantity   Int?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([world_id, item_id])
}

model BlackMarketUnlock {
  id            Int      @id @default(autoincrement())
  world_id      Int
  world         World    @relation(fields: [world_id], references: [id])
  item_type     String
  item_sub_type String
  is_unlocked   Boolean  @default(false)
  streetwise_dm Int      @default(0)
  unlocked_by   String?
  unlocked_day  Int?
  gm_override   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([world_id, item_type, item_sub_type])
}

model WorldNote {
  id           Int       @id @default(autoincrement())
  world_id     Int
  world        World     @relation(fields: [world_id], references: [id])
  character_id Int
  character    Character @relation(fields: [character_id], references: [id])
  note         String
  updated_at   DateTime  @updatedAt
}

model NPC {
  id                 Int                @id @default(autoincrement())
  world_id           Int?
  world              World?             @relation(fields: [world_id], references: [id])
  faction_id         Int?
  faction            Faction?           @relation(fields: [faction_id], references: [id])
  name               String
  description        String?
  occupation         String?
  alignment          String?
  reports_to_type    String?
  reports_to_id      Int?
  mission_text       String?
  total_investment   Int                @default(0)
  soc                Int                @default(7)
  ac                 Int                @default(0)
  last_investment_week Int?
  skills             String             @default("{}")
  portrait_url       String?
  is_revealed        Boolean            @default(false)
  is_hireable        Boolean            @default(false)
  hire_cost          Int?
  party_alignment    String?
  investment_actions InvestmentAction[] @relation("NPCInvestments")
  created_at         DateTime           @default(now())
}

model Faction {
  id                 Int                @id @default(autoincrement())
  name               String
  type               String
  alignment          String?
  size_code          Int
  world_id           Int
  world              World              @relation(fields: [world_id], references: [id])
  interaction_cost   Int                @default(0)
  total_investment   Int                @default(0)
  mission_text       String?
  portrait_url       String?
  is_revealed        Boolean            @default(false)
  party_alignment    String?
  npcs               NPC[]
  investment_actions InvestmentAction[] @relation("FactionInvestments")
  created_at         DateTime           @default(now())
}

model PiracyEffect {
  id                  Int      @id @default(autoincrement())
  world_id            Int
  world               World    @relation(fields: [world_id], references: [id])
  source_events       String   @default("[]")
  effect_start_level  Float
  effect_day_start    Int
  decay_rate          Float
  buy_price_modifier  Float    @default(0)
  sell_price_modifier Float    @default(0)
  updated_at          DateTime @updatedAt
}

model EncounterTable {
  id              Int      @id @default(autoincrement())
  name            String
  world_type      String
  environment     String?
  min_roll        Int
  max_roll        Int
  description     String
  generates_npc   Boolean  @default(false)
  npc_template    String?
  source          String?
  created_at      DateTime @default(now())
}

model SpecCargo {
  id                    Int         @id @default(autoincrement())
  world_id              Int
  world                 World       @relation(fields: [world_id], references: [id])
  trade_good            String
  trade_code            String
  tons_available        Int
  base_price_per_ton    Int
  visit_day             Int
  tons_taken            Int         @default(0)
  supplier_type         String      @default("standard")
  search_attempts_this_month Int    @default(0)
  rejected_day          Int?
  purchase_pct          Int?
  is_illegal            Boolean     @default(false)
  cargo_hold            CargoHold[]
  created_at            DateTime    @default(now())
}

model CargoHold {
  id                     Int       @id @default(autoincrement())
  spec_cargo_id          Int
  spec_cargo             SpecCargo @relation(fields: [spec_cargo_id], references: [id])
  character_id           Int
  character              Character @relation(fields: [character_id], references: [id])
  tons_purchased         Int
  purchase_price_per_ton Int
  purchased_day          Int
  sold_at_world_id       Int?
  sold_at_world          World?    @relation("CargoSoldAt", fields: [sold_at_world_id], references: [id])
  sale_price_per_ton     Int?
  sale_pct               Int?
  buyer_rejected_day     Int?
  sold_day               Int?
  created_at             DateTime  @default(now())
}

model FreightLot {
  id                   Int      @id @default(autoincrement())
  origin_world_id      Int
  origin_world         World    @relation("FreightOrigin", fields: [origin_world_id], references: [id])
  destination_world_id Int
  destination_world    World    @relation("FreightDestination", fields: [destination_world_id], references: [id])
  tons                 Int
  freight_class        String
  fee_per_ton          Int
  is_hazardous         Boolean  @default(false)
  status               String   @default("available")
  generated_day        Int
  accepted_day         Int?
  delivered_day        Int?
  gm_qty_override      Boolean  @default(false)
  created_at           DateTime @default(now())
}

model Passenger {
  id                   Int      @id @default(autoincrement())
  origin_world_id      Int
  origin_world         World    @relation("PassengerOrigin", fields: [origin_world_id], references: [id])
  destination_world_id Int
  destination_world    World    @relation("PassengerDestination", fields: [destination_world_id], references: [id])
  name                 String
  berth_class          String
  passage_fee          Int
  status               String   @default("available")
  generated_day        Int
  accepted_day         Int?
  delivered_day        Int?
  incident_notes       String?
  luggage_tons         Float    @default(0)
  gm_qty_override      Boolean  @default(false)
  created_at           DateTime @default(now())
}

model InventoryItem {
  id              Int        @id @default(autoincrement())
  item_id         Int
  item            Item       @relation(fields: [item_id], references: [id])
  owner_type      String
  owner_id        Int
  character       Character? @relation(fields: [owner_id], references: [id])
  quantity        Int        @default(1)
  equipped        Boolean    @default(false)
  is_hidden       Boolean    @default(false)
  notes           String?
  purchased_price Int?
  created_at      DateTime   @default(now())
}

model InvestmentAction {
  id           Int       @id @default(autoincrement())
  target_type  String
  target_id    Int
  npc          NPC?      @relation("NPCInvestments", fields: [target_id], references: [id])
  faction      Faction?  @relation("FactionInvestments", fields: [target_id], references: [id])
  character_id Int
  character    Character @relation(fields: [character_id], references: [id])
  action_type  String
  amount       Int
  description  String
  outcome      String
  av_at_time   Int
  skill_used   String?
  game_day     Int
  created_at   DateTime  @default(now())
}

model Ship {
  id                 Int            @id @default(autoincrement())
  name               String
  ship_class         String
  displacement_tons  Int
  hull_points        Int
  hull_damage        Int            @default(0)
  hull_severity      Int            @default(0)
  jump_rating        Int
  thrust_rating      Int
  current_thrust     Int?
  fuel_capacity      Int
  fuel_current       Int
  cargo_capacity     Int
  staterooms         Int            @default(0)
  cryopods           Int            @default(0)
  credits            Int            @default(0)
  mortgage_per_month Int?
  armour             Int            @default(0)
  notes              String?
  systems            ShipSystem[]
  weapons            ShipWeapon[]
  combat_objects     CombatObject[]
  created_at         DateTime       @default(now())
}

model ShipSystem {
  id                        Int              @id @default(autoincrement())
  ship_id                   Int
  ship                      Ship             @relation(fields: [ship_id], references: [id])
  name                      String
  system_type               String
  damage_state              String           @default("operational")
  damage_notes              String?
  hull_severity             Int              @default(0)
  maintenance_interval_days Int              @default(30)
  last_maintained_day       Int?
  maintenance_due_day       Int?
  overdue_penalty           String?
  maintenance_logs          MaintenanceLog[]
  created_at                DateTime         @default(now())
}

model ShipWeapon {
  id               Int      @id @default(autoincrement())
  ship_id          Int
  ship             Ship     @relation(fields: [ship_id], references: [id])
  name             String
  weapon_type      String
  mount_type       String
  tech_level       Int
  damage           String
  range            String
  cost             Int
  ammo_current     Int?
  ammo_max         Int?
  ammo_refill_cost Int?
  damage_state     String   @default("operational")
  hull_severity    Int      @default(0)
  turret_group     Int?
  notes            String?
  created_at       DateTime @default(now())
}

model MaintenanceLog {
  id               Int         @id @default(autoincrement())
  ship_system_id   Int?
  ship_system      ShipSystem? @relation(fields: [ship_system_id], references: [id])
  character_id     Int
  character        Character   @relation(fields: [character_id], references: [id])
  action_type      String
  description      String
  cost             Int?
  game_day         Int
  actions_consumed Boolean     @default(true)
  created_at       DateTime    @default(now())
}

model CrewMember {
  id                    Int       @id @default(autoincrement())
  name                  String
  position              String
  quality_tier          String
  specialty_skill       String
  specialty_dm          Int
  other_skills_dm       Int
  base_salary           Int
  monthly_salary        Int
  salary_arrears        Int       @default(0)
  hired_day             Int
  last_paid_day         Int?
  last_retention_day    Int?
  last_retention_week   Int?
  is_leaving            Boolean   @default(false)
  hired_by_character_id Int
  hired_by              Character @relation(fields: [hired_by_character_id], references: [id])
  status                String    @default("active")
  notes                 String?
  created_at            DateTime  @default(now())
}

model MissileSalvo {
  id               Int      @id @default(autoincrement())
  launched_day     Int
  launched_round   Int
  range_band       String
  missile_count    Int
  rounds_to_impact Int
  rounds_elapsed   Int      @default(0)
  status           String   @default("in_flight")
  created_at       DateTime @default(now())
}

model CombatSession {
  id             Int               @id @default(autoincrement())
  game_id        Int
  name           String
  active         Boolean           @default(true)
  current_phase  String            @default("SETUP")
  // 'SETUP'|'INITIATIVE'|'MANOEUVRE'|'ATTACK'|'ACTION'|'CLEANUP'
  current_round  Int               @default(1)
  created_at     DateTime          @default(now())
  ended_at       DateTime?
  objects        CombatObject[]
  ranges         CombatRange[]
  system_hits    CombatSystemHit[]
  boarding       BoardingAction?
  combat_roles   CharacterCombatRole[]
}

// End-of-round cleanup resets per CombatObject:
//   move_intent    → reset to null
//   move_target_id → reset to null
//   thrust_spent   → reset to 0
model CombatObject {
  id                         Int                 @id @default(autoincrement())
  session_id                 Int
  session                    CombatSession       @relation(fields: [session_id], references: [id])
  ship_id                    Int?
  ship                       Ship?               @relation(fields: [ship_id], references: [id])
  object_type                String
  // 'SHIP'|'PLANET'|'STATION'|'MISSILE_SALVO'
  name                       String
  is_player_ship             Boolean             @default(false)
  is_destroyed               Boolean             @default(false)
  is_active                  Boolean             @default(true)
  added_round                Int                 @default(1)
  initiative                 Int?

  // Movement intent — reset to null each round during cleanup
  move_intent                String?
  // 'CLOSE'|'FLEE'|'HOLD' — null means no movement this round
  move_target_id             Int?
  // ID of the object this object is moving relative to
  // null for planets, stations, and objects that did not move
  thrust_spent               Int                 @default(0)
  // thrust points committed this round, reset to 0 during cleanup

  // Ship core stats
  tl                         Int?
  size_tons                  Int?
  max_thrust                 Int?
  adjusted_max_thrust        Int?
  current_thrust             Int?
  base_armor                 Int?
  current_armor              Int?
  hull_max                   Int?
  hull_current               Int?
  hull_severity              Int                 @default(0)
  sustained_damage_threshold Int?
  fuel_capacity              Float?
  fuel_current               Float?
  fuel_leak_rate             Float               @default(0)
  fuel_tank_status           String?             // 'Intact'|'Destroyed'
  power_max                  Float?
  power_max_base             Float?              // immutable base; power_max is current (reduced by crits)
  power_used                 Float?
  computer_rating            Int?
  current_computer_rating    Int?
  computer_status            String?
  // 'Operational'|'Disabled'|'Destroyed'
  life_support_status        String?
  // 'Operational'|'Failing'|'Failed'
  life_support_timer         Int?
  j_drive_check_dm           Int                 @default(0)
  j_drive_status             String?
  // 'Operable'|'Disabled'|'Damaged'|'Destroyed'
  m_drive_check_dm           Int                 @default(0)
  m_drive_thrust_mod         Int                 @default(0)
  m_drive_status             String?
  // 'Operable'|'Operable - Damaged'|'Destroyed'
  cargo_weight               Float?
  cargo_value                Float?
  cargo_status               String?             // 'Intact'|'Destroyed'
  sensor_check_dm            Int                 @default(0)
  sensor_range               String?
  // 'Distant'|'Medium'|'Short'|'Close'|'Adjacent'
  sensor_status              String?             // 'Operable'|'Disabled'
  sensor_lock_status         String              @default("NO SENSOR LOCK")
  // 'SENSOR LOCKED'|'NO SENSOR LOCK'
  comms_jammed               Boolean             @default(false)
  overload_drive_dm          Int                 @default(0)
  overload_power_dm          Int                 @default(0)
  increase_thrust_next       Boolean             @default(false)
  increase_power_next        Boolean             @default(false)
  ew_used                    Boolean             @default(false)
  leadership_effect          Int                 @default(0)

  // NPC crew skill DMs (for GM-controlled ships)
  pilot_skill_dm             Int?
  leadership_skill_dm        Int?
  naval_tactics_dm           Int?
  captain_soc_dm             Int?
  gunner_skill_dm            Int?
  gunner_dex_dm              Int?
  engineer_skill_dm          Int?
  engineer_int_dm            Int?
  sensor_op_skill_dm         Int?
  sensor_op_int_dm           Int?
  marines                    Int                 @default(0)
  passengers                 Int                 @default(0)

  // Missile salvo specific
  origin_object_id           Int?
  target_object_id           Int?
  missile_thrust             Int?
  missile_quantity           Int?
  rounds_to_contact          Int?

  // Planet specific
  radius_km                  Int?
  jump_distance_km           Int?

  ranges_from                CombatRange[]       @relation("RangeFrom")
  ranges_to                  CombatRange[]       @relation("RangeTo")
  system_hits                CombatSystemHit[]
  weapon_mounts              CombatWeaponMount[]
  crew_members               CombatCrewMember[]
  repair_progress            RepairProgress[]
}

// DEVELOPER NOTE — Range model conventions:
//
// Range between any two objects is symmetrical. Only one CombatRange
// record exists per pair. At creation time, always store the record
// as (lower_id → higher_id) to enforce consistency.
//
// When querying range between object A and object B, check for either:
//   (from_object_id = A.id AND to_object_id = B.id)
//   OR
//   (from_object_id = B.id AND to_object_id = A.id)
// whichever exists is the correct record.
//
// When resolving movement, find all CombatRange records involving the
// moving object. For each range pair, determine net thrust point change:
//
//   Both objects CLOSE on each other  → subtract both thrust_spent values
//   Both objects FLEE from each other → add both thrust_spent values
//   One CLOSE, one FLEE               → subtract the difference
//   One moves, one HOLDS              → apply only the mover's thrust_spent
//
// After updating thrust_points, recalculate band using the thresholds above.
// Clamp thrust_points to minimum 0 (cannot go below ADJACENT).
//
// DIAGRAM RENDERING — ego-centric, always built from one reference object:
//
// To render the combat diagram for any object (player ship or GM ship):
//   1. Set that object as the reference — it always appears at the far left
//   2. Query all CombatRange records where from_object_id OR to_object_id
//      equals the reference object's id
//   3. Place each other object in the column matching its band value
//   4. Render directional arrows from each other object's move_intent:
//      - other.move_target_id == reference.id AND move_intent == 'CLOSE' → <<
//      - other.move_target_id == reference.id AND move_intent == 'FLEE'  → >>
//      - other.move_target_id != reference.id AND move_intent == 'CLOSE' → <
//      - other.move_target_id != reference.id AND move_intent == 'FLEE'  → >
//      - move_intent == 'HOLD' or null → no arrow
//
// The diagram component must accept a referenceObjectId prop so it can
// be rendered from any object's perspective without code changes.
model CombatRange {
  id                 Int           @id @default(autoincrement())
  session_id         Int
  session            CombatSession @relation(fields: [session_id], references: [id])
  from_object_id     Int
  from_object        CombatObject  @relation("RangeFrom", fields: [from_object_id], references: [id])
  to_object_id       Int
  to_object          CombatObject  @relation("RangeTo", fields: [to_object_id], references: [id])
  thrust_points      Int           @default(44)
  // thrust point difference between the two objects
  // band thresholds:
  // 0-1:   ADJACENT
  // 1-2:   CLOSE
  // 2-4:   SHORT
  // 4-9:   MEDIUM
  // 9-19:  LONG
  // 19-44: VERY LONG
  // 44-94: DISTANT
  band               String        @default("VERY LONG")
  last_updated_round Int           @default(1)

  @@unique([session_id, from_object_id, to_object_id])
}

model CombatSystemHit {
  id             Int           @id @default(autoincrement())
  session_id     Int
  session        CombatSession @relation(fields: [session_id], references: [id])
  object_id      Int
  object         CombatObject  @relation(fields: [object_id], references: [id])
  system_name    String
  // 'Sensors'|'Power Plant'|'Fuel'|'Weapon'|'Armor'|'Hull'|
  // 'M-Drive'|'Cargo'|'J-Drive'|'Crew'|'Computer'
  severity       Int           @default(1)
  max_severity   Int           @default(1)
  repaired       Boolean       @default(false)
  beyond_repair  Boolean       @default(false)
  recorded_round Int           @default(1)
  created_at     DateTime      @default(now())

  @@unique([session_id, object_id, system_name])
}

model CombatWeaponMount {
  id               Int            @id @default(autoincrement())
  object_id        Int
  object           CombatObject   @relation(fields: [object_id], references: [id])
  mount_type       String
  // 'Fixed'|'Single Turret'|'Double Turret'|'Triple Turret'
  mount_status     String         @default("Operational")
  // 'Operational'|'Bane'|'Disabled'|'Destroyed'
  point_defense_dm Int            @default(0)
  ammo_status      String         @default("Full")
  // 'Full'|'Fired'|'Reloading'|'Empty'
  weapons          CombatWeapon[]
}

model CombatWeapon {
  id             Int               @id @default(autoincrement())
  mount_id       Int
  mount          CombatWeaponMount @relation(fields: [mount_id], references: [id])
  weapon_type    String
  // 'Beam Laser'|'Pulse Laser'|'Missile Rack'|'Sandcaster'|'Ion Cannon'
  damage         String
  range          String
  traits         String?
  ammo_count     Int               @default(0)
  power_required Int               @default(0)
}

model CombatCrewMember {
  id         Int          @id @default(autoincrement())
  object_id  Int
  object     CombatObject @relation(fields: [object_id], references: [id])
  name       String
  role       String
  hp_max     Int
  hp_current Int
  status     String       @default("Active")
  // 'Active'|'Wounded'|'Incapacitated'|'Dead'
}

model RepairProgress {
  id                Int          @id @default(autoincrement())
  object_id         Int
  object            CombatObject @relation(fields: [object_id], references: [id])
  character_id      Int
  system_name       String
  consecutive_bonus Int          @default(0)

  @@unique([object_id, character_id])
}

model BoardingAction {
  id                  Int           @id @default(autoincrement())
  session_id          Int           @unique
  session             CombatSession @relation(fields: [session_id], references: [id])
  attacker_object_id  Int
  defender_object_id  Int
  phase               String        @default("RESOLUTION")
  // 'RESOLUTION'|'PACIFICATION'
  rounds_remaining    Int?
  pacification_timer  Int?
  pacification_paused Boolean       @default(false)
  carry_forward_dm    Int           @default(0)
}

model CombatConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model CharacterCombatRole {
  id           Int           @id @default(autoincrement())
  session_id   Int
  session      CombatSession @relation(fields: [session_id], references: [id])
  character_id Int
  character    Character     @relation(fields: [character_id], references: [id])
  role         String
  // 'CAPTAIN'|'PILOT'|'GUNNER'|'ENGINEER'|'SENSOR OPERATOR'|'MARINE'|'PASSENGER'
  mount_id     Int?
  // only populated when role = 'GUNNER'
  confirmed    Boolean       @default(false)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@unique([session_id, character_id])
}

model EventLog {
  id           Int        @id @default(autoincrement())
  game_day     Int
  event_type   String
  character_id Int?
  character    Character? @relation(fields: [character_id], references: [id])
  world_id     Int?
  world        World?     @relation(fields: [world_id], references: [id])
  description  String
  is_public    Boolean    @default(true)
  created_at   DateTime   @default(now())
}

model Message {
  id             Int      @id @default(autoincrement())
  from_player_id Int
  from_player    Player   @relation("SentMessages", fields: [from_player_id], references: [id])
  to_player_id   Int?
  to_player      Player?  @relation("ReceivedMessages", fields: [to_player_id], references: [id])
  recipient_type String   @default("all")
  body           String
  is_read        Boolean  @default(false)
  game_day       Int
  created_at     DateTime @default(now())
}
